2. 最后一行输出：HYPERLOOP_TASK_DONE
WINIT

    # 构造完整 prompt（WRITER_INIT + 项目简报 + BDD + 契约 + TASK），通过 stdin 注入
    local WRITER_PROMPT="${WT}/_writer_prompt.md"
